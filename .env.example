# ──────────────────────────────────────────────────
# HAVEN — Environment Variables Reference
# ──────────────────────────────────────────────────
# Copy relevant variables to:
#   backend/.env          (for the Go server)
#   frontend/.env.local   (for the Next.js app)
# ──────────────────────────────────────────────────

# ── App ──────────────────────────────────────────
APP_ENV=development                        # development | staging | production
APP_PORT=8080                              # Go HTTP server port
APP_FRONTEND_URL=http://localhost:3000     # CORS allowed origin

# ── PostgreSQL ───────────────────────────────────
# Development: Docker container (see docker-compose.yml)
# Production:  Neon Serverless PostgreSQL
DATABASE_URL=postgres://haven:haven@localhost:5432/haven_dev?sslmode=disable
# Production example:
# DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/haven?sslmode=require

# ── Redis ────────────────────────────────────────
# Development: Docker container
# Production:  Upstash Redis
REDIS_URL=redis://localhost:6379/0
# Production example:
# REDIS_URL=rediss://default:xxx@us1-xxx.upstash.io:6379

# ── OpenSearch / ElasticSearch ───────────────────
# Development: Docker container
# Production:  Managed OpenSearch (AWS/Bonsai)
OPENSEARCH_URL=http://localhost:9200
# Production example:
# OPENSEARCH_URL=https://search-haven-xxx.us-east-1.es.amazonaws.com
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# ── JWT / Auth ───────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# ── OAuth 2.0 — Google ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# ── OAuth 2.0 — GitHub ───────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/github/callback

# ── WebSocket ────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30s
WS_PRESENCE_TTL=60s

# ── AI / Gemini (Phase 7) ────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768

# ── SMTP / Magic Links (Phase 8) ─────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@haven.social
MAGIC_LINK_TOKEN_EXPIRY=15m

# ── GitHub Webhooks (Phase 6) ────────────────────
GITHUB_WEBHOOK_SECRET=

# ── File Storage / S3 (Media Uploads) ────────────
S3_BUCKET_NAME=haven-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000

# ── Frontend (.env.local) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
NEXT_PUBLIC_APP_NAME=Haven
